generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- 1. USERS & ACCOUNTS ---

model users {
  id                 Int           @id @default(autoincrement())
  first_name         String        @db.VarChar(100)
  last_name          String        @db.VarChar(100)
  address            String       @db.VarChar(255)
  email              String        @unique @db.VarChar(255)
  password           String        @db.VarChar(255)
  mobile             String?       @db.VarChar(20)
  gender             Gender?
  role               String?       @default("student") @db.VarChar(20)

  is_email_verified  Boolean       @default(false)
  is_blocked         Boolean       @default(false)

  created_at         DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?     @updatedAt @db.Timestamptz(6)

  cart_items         cart_items[]
  purchases          purchases[]
  enrollments        enrollments[]
  verificationTokens VerificationToken[]
}

enum Gender {
  male
  female
  other
}

// --- 2. COURSES & MATERIALS ---

enum CourseType {
  theory
  pastpaper
}

model courses {
  id            Int            @id @default(autoincrement())
  title         String         @db.VarChar(255)
  grade         Int?           // Optional: Null for common Past Papers
  type          CourseType     @default(theory)
  price         Int            @default(0) 
  is_published  Boolean        @default(false)
  
  created_at    DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?      @updatedAt @db.Timestamptz(6)

  lessons       lessons[]
  resources     resources[]    // Direct relation for Past Papers/General docs
  cart_items    cart_items[]
  purchase_items purchase_items[]
  enrollments   enrollments[]
}

model lessons {
  id          Int         @id @default(autoincrement())
  course_id   Int
  title       String      @db.VarChar(255)
  sequence    Int         @default(0)
  
  course      courses     @relation(fields: [course_id], references: [id], onDelete: Cascade)
  resources   resources[]
}

model resources {
  id          Int       @id @default(autoincrement())
  course_id   Int
  lesson_id   Int?      
  title       String    @db.VarChar(255)
  type        String    @db.VarChar(255) // e.g., "video", "pdf", "link"
  file_url    String    @db.VarChar(500)
  sequence    Int       @default(0)
  
  course      courses   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lesson      lessons?  @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
}

// --- 3. E-COMMERCE ---

model cart_items {
  id          Int       @id @default(autoincrement())
  user_id     Int
  course_id   Int
  added_at    DateTime? @default(now()) @db.Timestamptz(6)

  user        users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course      courses   @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@unique([user_id, course_id])
}

model purchases {
  id                Int             @id @default(autoincrement())
  user_id           Int
  stripe_session_id String?         @unique
  total_amount      Decimal         @db.Decimal(10, 2)
  status            PurchaseStatus  @default(COMPLETED)
  purchased_at      DateTime?       @default(now()) @db.Timestamptz(6)

  user              users           @relation(fields: [user_id], references: [id], onDelete: Restrict)
  items             purchase_items[]
}

model purchase_items {
  id           Int       @id @default(autoincrement())
  purchase_id  Int
  course_id    Int
  price_paid   Decimal   @db.Decimal(10, 2)

  purchase     purchases @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  course       courses   @relation(fields: [course_id], references: [id], onDelete: Restrict)
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
}

// --- 4. ACCESS & ENROLLMENT ---

model enrollments {
  id          Int         @id @default(autoincrement())
  user_id     Int
  course_id   Int
  enrolled_at DateTime?   @default(now()) @db.Timestamptz(6)
  expires_at  DateTime?   @db.Timestamptz(6)
  is_active   Boolean     @default(true)
  tute_sent     Boolean   @default(false)
  tute_sent_at  DateTime? @db.Timestamptz(6)

  user        users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course      courses   @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@unique([user_id, course_id])
}

model VerificationToken {
  id         Int        @id @default(autoincrement())
  email      String     @db.VarChar(255)
  token      String     @unique
  type       TokenType 
  expires    DateTime
  userId     Int
  user       users      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([email, token])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  MOBILE_VERIFICATION
}

model system_settings {
  key   String @id @db.VarChar(50)
  value String @db.Text
}